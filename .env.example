# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: The PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_esportiva"

# JWT_SECRET: Secret for signing JWT authentication tokens
JWT_SECRET="super-secret-jwt-key"

# ADMIN_PASSWORD: Default admin user password seeded during DB initialization
ADMIN_PASSWORD="admin"

